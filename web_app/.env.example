# Flask
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-64-char-hex-string

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Google Cloud Storage
GCS_BUCKET_URL=https://storage.googleapis.com/your-bucket-name

# Speaking practice
# Download a Chinese Vosk model and point this to the extracted model folder.
# Default if unset: web_app/models/vosk-model-small-cn-0.22
VOSK_MODEL_PATH=
SPEAKING_SCORE_THRESHOLD=80
SPEAKING_MAX_AUDIO_BYTES=5242880
